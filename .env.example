# Base URL for the Leasebase API.
# Local dev: http://localhost:4000
# Deployed dev: https://api.dev.leasebase.ai
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Base domain (used for domain-level checks, not URL construction).
# Default: leasebase.ai
NEXT_PUBLIC_APP_DOMAIN=leasebase.ai

# Full base URL for the web app (used by middleware for redirect targets).
# Local dev: http://localhost:3000
# Deployed dev: https://app.dev.leasebase.ai
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AWS Cognito configuration for the web app
NEXT_PUBLIC_COGNITO_REGION=us-west-2
NEXT_PUBLIC_COGNITO_USER_POOL_ID=your_cognito_user_pool_id
NEXT_PUBLIC_COGNITO_CLIENT_ID=your_cognito_app_client_id

# Dev-only mock auth toggle
# When true and NODE_ENV !== "production", the app may expose a dev-only
# login/bypass flow. This MUST remain false in production.
DEV_ONLY_MOCK_AUTH=false
NEXT_PUBLIC_DEV_ONLY_MOCK_AUTH=false

# Old-domain redirect feature flag.
# When true, requests to *.leasebase.co are 301-redirected to the new domain.
# Set to "true" after new-domain validation passes.
ENABLE_OLD_DOMAIN_REDIRECTS=false
OLD_DOMAIN=leasebase.co

# PostHog analytics (optional — omit to disable tracking)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Calendly scheduling link (optional — omit to hide CTA)
NEXT_PUBLIC_CALENDLY_URL=
