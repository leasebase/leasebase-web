<!-- ==========================================================
     LEASEBASE CONTACT PAGE — GUTENBERG BLOCK CONTENT
     ==========================================================
     HOW TO USE (if the FSE template page-contact.html is not
     auto-applied by WordPress):
     1. Go to WP Admin → Pages → Contact (slug: contact)
     2. Switch to the Code Editor (⋮ menu → Code editor)
     3. Select ALL existing content and DELETE it
     4. Paste this entire file content
     5. Switch back to Visual Editor to verify
     6. Click Update / Publish
     7. Ensure the page uses the "Contact" template (Page Attributes
        panel → Template → Contact) if available, otherwise the
        FSE template page-contact.html should apply automatically
        for the slug "contact".
     ========================================================== -->


<!-- HERO -->
<!-- wp:group {"className":"lb-contact-hero lb-section","layout":{"type":"constrained"}} -->
<div class="wp-block-group lb-contact-hero lb-section">

<!-- wp:heading {"level":1,"textAlign":"center"} -->
<h1 class="wp-block-heading has-text-align-center">Get in Touch</h1>
<!-- /wp:heading -->

<!-- wp:paragraph {"align":"center","className":"lb-contact-hero-sub"} -->
<p class="has-text-align-center lb-contact-hero-sub">Have a question, need support, or want to talk about your property portfolio? We're here to help.</p>
<!-- /wp:paragraph -->

</div>
<!-- /wp:group -->


<!-- CONTACT FORM + INFO -->
<!-- wp:group {"className":"lb-section lb-contact-layout-section","layout":{"type":"constrained"}} -->
<div class="wp-block-group lb-section lb-contact-layout-section">

<!-- wp:html -->
<div class="lb-contact-layout">

  <!-- Contact Form -->
  <div class="lb-contact-form-wrap">
    <h2 class="lb-contact-form-heading">Send us a message</h2>
    <p class="lb-contact-form-sub">We typically reply within one business day.</p>

    <form id="lb-contact-form" class="lb-contact-form" novalidate>

      <div class="lb-form-row lb-form-row--2col">
        <div class="lb-form-field">
          <label for="lb-contact-name" class="lb-form-label">Full Name <span aria-hidden="true">*</span></label>
          <input
            type="text"
            id="lb-contact-name"
            name="name"
            class="lb-form-input"
            placeholder="Jane Smith"
            required
            autocomplete="name"
          />
        </div>
        <div class="lb-form-field">
          <label for="lb-contact-email" class="lb-form-label">Email Address <span aria-hidden="true">*</span></label>
          <input
            type="email"
            id="lb-contact-email"
            name="email"
            class="lb-form-input"
            placeholder="jane@example.com"
            required
            autocomplete="email"
          />
        </div>
      </div>

      <div class="lb-form-field">
        <label for="lb-contact-subject" class="lb-form-label">Subject</label>
        <select id="lb-contact-subject" name="subject" class="lb-form-input lb-form-select">
          <option value="general">General Inquiry</option>
          <option value="sales">Sales &amp; Pricing</option>
          <option value="support">Product Support</option>
          <option value="partnership">Partnership</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div class="lb-form-field">
        <label for="lb-contact-message" class="lb-form-label">Message <span aria-hidden="true">*</span></label>
        <textarea
          id="lb-contact-message"
          name="message"
          class="lb-form-input lb-form-textarea"
          placeholder="Tell us how we can help..."
          rows="6"
          required
        ></textarea>
      </div>

      <div id="lb-contact-status" class="lb-contact-status" aria-live="polite" hidden></div>

      <button type="submit" id="lb-contact-submit" class="lb-contact-submit">
        Send Message
      </button>

    </form>
  </div>

  <!-- Contact Info Sidebar -->
  <aside class="lb-contact-info">

    <div class="lb-contact-info-card">
      <div class="lb-contact-info-icon" aria-hidden="true">✉️</div>
      <h3 class="lb-contact-info-heading">Email Us</h3>
      <p class="lb-contact-info-body">For general questions or if you prefer email:</p>
      <a href="mailto:info@leasebase.ai" class="lb-contact-info-link">info@leasebase.ai</a>
    </div>

    <div class="lb-contact-info-card">
      <div class="lb-contact-info-icon" aria-hidden="true">🚀</div>
      <h3 class="lb-contact-info-heading">Ready to get started?</h3>
      <p class="lb-contact-info-body">Sign up free — no credit card required. Get up and running in minutes.</p>
      <a href="https://signup.dev.leasebase.ai" class="lb-nav-btn lb-contact-signup-btn">Sign Up Free</a>
    </div>

    <div class="lb-contact-info-card">
      <div class="lb-contact-info-icon" aria-hidden="true">⏱️</div>
      <h3 class="lb-contact-info-heading">Response Time</h3>
      <p class="lb-contact-info-body">We respond to all inquiries within one business day.</p>
    </div>

  </aside>

</div>
<!-- /wp:html -->

</div>
<!-- /wp:group -->


<!-- CONTACT FORM SCRIPT -->
<!-- wp:html -->
<script>
(function () {
  var form = document.getElementById('lb-contact-form');
  var statusEl = document.getElementById('lb-contact-status');
  var submitBtn = document.getElementById('lb-contact-submit');
  if (!form) return;

  function showStatus(msg, isError) {
    statusEl.textContent = msg;
    statusEl.className = 'lb-contact-status ' + (isError ? 'lb-contact-status--error' : 'lb-contact-status--success');
    statusEl.hidden = false;
  }

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var name    = (form.elements['name'].value || '').trim();
    var email   = (form.elements['email'].value || '').trim();
    var subject = form.elements['subject'].value || 'general';
    var message = (form.elements['message'].value || '').trim();

    if (!name) { showStatus('Please enter your name.', true); form.elements['name'].focus(); return; }
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showStatus('Please enter a valid email address.', true); form.elements['email'].focus(); return; }
    if (!message) { showStatus('Please enter a message.', true); form.elements['message'].focus(); return; }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';
    statusEl.hidden = true;

    fetch('/wp-json/leasebase/v1/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name: name, email: email, subject: subject, message: message })
    })
      .then(function (res) { return res.json(); })
      .then(function (data) {
        if (data.success) {
          showStatus(data.message || "Thanks! We'll be in touch soon.", false);
          form.reset();
        } else {
          showStatus(data.message || 'Something went wrong. Please try again.', true);
        }
      })
      .catch(function () {
        showStatus('Network error. Please check your connection and try again.', true);
      })
      .finally(function () {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Message';
      });
  });
})();
</script>
<!-- /wp:html -->
